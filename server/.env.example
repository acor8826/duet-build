# Required
OPENAI_API_KEY=

# Model + behavior
OPENAI_PARTNER_MODEL=gpt-5.6
DUET_OPUS_MODEL=claude-fable-5
DUET_ITERATION_CAP=8
DUET_CONFIDENCE_THRESHOLD=95
# GPT reasoning effort (Responses API supports tools + reasoning together).
# Empty = model default. Output cap covers reasoning + visible output.
DUET_GPT_REASONING_EFFORT=medium
DUET_MAX_OUTPUT_TOKENS=8000

# Cap on a single orchestrator-provided tool result handed back to GPT
DUET_MAX_TOOL_RESULT_CHARS=60000
# Optional: GCS bucket for durable session state (suspended turns survive
# server restarts / Cloud Run instance recycling during long research pauses)
# DUET_STATE_GCS_BUCKET=asc-router-duet-state

# Transport: stdio (local) or http (Cloud Run)
DUET_TRANSPORT=stdio

# State directory (host paths; on Cloud Run point at a writable /tmp subdir)
DUET_STATE_DIR=C:\Users\acor8\.claude\duet

# HTTP-only
PORT=8080
